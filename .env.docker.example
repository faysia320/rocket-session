# === Claude CLI 인증 ===
# 호스트의 ~/.claude 디렉토리 절대 경로
CLAUDE_AUTH_DIR=C:\Users\username\.claude
# 호스트의 ~/.claude.json 파일 절대 경로
CLAUDE_AUTH_FILE=C:\Users\username\.claude.json

# === Claude 설정 ===
CLAUDE_ALLOWED_TOOLS=Read,Write,Edit,Bash

# === Git 설정 (선택사항) ===
# 컨테이너 내부에서 git commit/push 시 사용할 사용자 정보
GIT_USER_NAME=
GIT_USER_EMAIL=
# GitHub Personal Access Token (Fine-grained) - HTTPS 인증용
# 워크스페이스 git clone/push/pull에 필요합니다.
# 생성 방법:
#   1. GitHub > Settings > Developer settings > Personal access tokens > Fine-grained tokens
#   2. "Generate new token" 클릭
#   3. Repository access: 필요한 저장소 선택
#   4. Permissions: Contents (Read and write) 권한 부여
#   5. 생성된 토큰을 아래에 설정
GITHUB_TOKEN=

# === 서버 설정 ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8101

# === CORS 설정 (선택사항) ===
# LAN/외부 접속 시 추가 허용 origin (쉼표 구분)
# 예: http://192.168.1.100:8100,http://myserver.local:8100
CORS_EXTRA_ORIGINS=

# === GlitchTip (Self-hosted 에러 추적) ===
# GlitchTip 시크릿 키 (랜덤 문자열, 필수)
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
GLITCHTIP_SECRET_KEY=
# GlitchTip 외부 접근 URL
GLITCHTIP_DOMAIN=http://localhost:8200

# === Sentry SDK (GlitchTip DSN) ===
# 초기 설정 후 GlitchTip 대시보드에서 DSN 확인
# 형식: http://<key>@localhost:8200/<project-id>
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
