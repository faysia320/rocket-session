{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "시간별 세션 활동",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"backend\", operation=\"connect\"} [5m]))",
          "legendFormat": "연결",
          "refId": "A"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"backend\", operation=\"message_receive\"} [5m]))",
          "legendFormat": "프롬프트",
          "refId": "B"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"backend\", operation=\"result_received\"} | json | is_error=\"true\" [5m]))",
          "legendFormat": "에러",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2,
            "drawStyle": "line"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "에러" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "평균 턴 소요시간 (ms)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "avg_over_time({service=\"backend\", operation=\"result_received\"} | json | unwrap duration_ms [$__range])",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 30000 },
              { "color": "red", "value": 120000 }
            ]
          }
        }
      }
    },
    {
      "title": "에러율",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"backend\", operation=\"result_received\"} | json | is_error=\"true\" [$__range])) / sum(count_over_time({service=\"backend\", operation=\"result_received\"} [$__range])) * 100",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "워크플로우 완료 수",
      "type": "stat",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service=\"backend\", component=\"workflow\", operation=\"completed\"} [$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      }
    },
    {
      "title": "비용 추이 (USD)",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum_over_time({service=\"backend\", operation=\"result_received\"} | json | unwrap cost_usd [1h])",
          "legendFormat": "비용",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "custom": {
            "fillOpacity": 30,
            "lineWidth": 2,
            "drawStyle": "bars"
          }
        }
      }
    },
    {
      "title": "컴포넌트별 활동 분포",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by(component) (count_over_time({service=\"backend\", component=~\".+\"} [$__range]))",
          "refId": "A"
        }
      ]
    },
    {
      "title": "최근 세션 로그 스트림",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"backend\", component=~\".+\", operation=~\"connect|disconnect|turn_start|turn_end|result_received\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sessions-overview", "rocket-session"],
  "templating": { "list": [] },
  "time": { "from": "now-24h", "to": "now" },
  "title": "Rocket Session - Sessions Overview",
  "uid": "rocket-sessions-overview"
}
